generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  MEMBER
  VIEWER
}

model User {
  id           String         @id @default(cuid())
  name         String
  email        String         @unique
  password     String
  avatar       String?
  createdAt    DateTime       @default(now())
  boards       Board[]
  boardMembers BoardMember[]
  activities   Activity[]
  notifications Notification[]
  comments     Comment[]
}

model Board {
  id          String        @id @default(cuid())
  title       String
  background  String        @default("#0079bf")
  userId      String
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  members     BoardMember[]
  lists       List[]
  labels      Label[]
  notifications Notification[]
}

model BoardMember {
  id      String @id @default(cuid())
  boardId String
  userId  String
  role    Role   @default(MEMBER)
  board   Board  @relation(fields: [boardId], references: [id], onDelete: Cascade)
  user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([boardId, userId])
}

model List {
  id        String   @id @default(cuid())
  title     String
  position  Int
  boardId   String
  createdAt DateTime @default(now())
  board     Board    @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards     Card[]
}

model Card {
  id          String      @id @default(cuid())
  title       String
  description String?
  position    Int
  listId      String
  dueDate     DateTime?
  coverColor  String?
  createdAt   DateTime    @default(now())
  list        List        @relation(fields: [listId], references: [id], onDelete: Cascade)
  labels      CardLabel[]
  checklists  Checklist[]
  attachments Attachment[]
  activities  Activity[]
  comments    Comment[]
}

model Label {
  id      String      @id @default(cuid())
  name    String
  color   String
  boardId String
  board   Board       @relation(fields: [boardId], references: [id], onDelete: Cascade)
  cards   CardLabel[]
}

model CardLabel {
  cardId  String
  labelId String
  card    Card  @relation(fields: [cardId], references: [id], onDelete: Cascade)
  label   Label @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([cardId, labelId])
}

model Checklist {
  id     String          @id @default(cuid())
  title  String
  cardId String
  card   Card            @relation(fields: [cardId], references: [id], onDelete: Cascade)
  items  ChecklistItem[]
}

model ChecklistItem {
  id          String    @id @default(cuid())
  content     String
  isCompleted Boolean   @default(false)
  checklistId String
  checklist   Checklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
}

model Attachment {
  id        String   @id @default(cuid())
  filename  String
  url       String
  cardId    String
  createdAt DateTime @default(now())
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String   @id @default(cuid())
  message   String
  type      String
  isRead    Boolean  @default(false)
  userId    String
  boardId   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  board     Board?   @relation(fields: [boardId], references: [id], onDelete: SetNull)
}

model Comment {
  id        String   @id @default(cuid())
  content   String
  cardId    String
  userId    String
  createdAt DateTime @default(now())
  card      Card     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Activity {
  id        String   @id @default(cuid())
  action    String
  cardId    String?
  userId    String
  createdAt DateTime @default(now())
  card      Card?    @relation(fields: [cardId], references: [id], onDelete: SetNull)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
